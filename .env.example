# Supabase — copy this file to `.env.local` and fill in your project's values.
# Found in: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key. NEVER expose this to the browser. Used by admin/server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Admin iOS / web push (Home Screen PWA notifications)
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# ---------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:Nailtekandspa52018@yahoo.com

# Protects /api/cron/appointment-reminders
# Call every minute from an external cron (cron-job.org, EasyCron, etc.):
#   GET https://your-domain/api/cron/appointment-reminders
#   Header: Authorization: Bearer <CRON_SECRET>
# (Vercel Hobby cannot run every-minute crons; Pro can via vercel.json.)
CRON_SECRET=generate-a-long-random-string
